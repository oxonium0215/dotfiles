{{ if and (eq .chezmoi.os "linux") (contains "microsoft" (lower .chezmoi.kernel.osrelease)) -}}
[Unit]
Description=Bitwarden SSH Agent Forwarding (npiperelay)
After=network.target

[Service]
Type=simple
# Ensure no stale socket exists before starting
ExecStartPre=/usr/bin/rm -f %t/ssh-agent.sock
# socat listens on UNIX socket; for each connection, run the retry wrapper
ExecStart=socat UNIX-LISTEN:%t/ssh-agent.sock,fork,reuseaddr EXEC:%h/.local/bin/npiperelay-retry.sh,nofork

Restart=always
RestartSec=2

[Install]
WantedBy=default.target
{{ end -}}
