ZSHRC_DIR=~/.config/zsh
# source command override technique to automatically compile scripts
function source {
  if [[ -n "$1" ]]; then
    ensure_zcompiled "$1"
  fi
  builtin source "$@"
}

function ensure_zcompiled {
    local script="$1"
    [[ ! -f "$script" ]] && return
    
    local compiled="$script.zwc"
    if [[ ! -r "$compiled" || "$script" -nt "$compiled" ]]; then
        # Try to compile only if we have write permission to the directory
        if [[ -w "$(dirname "$script")" ]]; then
            zcompile "$script" 2>/dev/null || true
        fi
    fi
}
ensure_zcompiled ~/.zshrc

# 1. Load basic environment (including PATH setup for mise/sheldon)
source $ZSHRC_DIR/nonlazy.zsh

# 2. Load plugins via sheldon cache
# (Cache is managed/generated by chezmoi)
export SHELDON_CONFIG_DIR="$ZSHRC_DIR/sheldon"
sheldon_cache="$SHELDON_CONFIG_DIR/sheldon.zsh"
if [[ -r "$sheldon_cache" ]]; then
  source "$sheldon_cache"
else
  # Fallback: if cache is missing, try to generate it if sheldon is available
  if command -v sheldon >/dev/null 2>&1; then
    # Try to generate cache, but don't fail if directory is read-only
    if [[ -w "$(dirname "$sheldon_cache")" ]]; then
        sheldon source > "$sheldon_cache" 2>/dev/null && source "$sheldon_cache"
    else
        eval "$(sheldon source)"
    fi
  fi
fi
unset sheldon_cache

# Dummy zsh-defer fallback to prevent errors if plugin failed to load
if ! command -v zsh-defer >/dev/null 2>&1; then
  function zsh-defer() {
    # Simple fallback: ignore options and just execute
    local opt
    OPTIND=1
    while getopts "t:" opt; do
      case "$opt" in
        t) ;;
      esac
    done
    shift $((OPTIND-1))
    eval "$@"
  }
fi

# 3. Load deferred/lazy configurations
zsh-defer source $ZSHRC_DIR/lazy.zsh
zsh-defer unfunction source

# Load machine-specific local configuration (not managed by chezmoi)
if [[ -f ~/.zshrc.local ]]; then
  source ~/.zshrc.local
fi
