# mise global configuration
# Managed by chezmoi

[settings]
# Trust all config files in home directory
trusted_config_paths = ["~"]
# Automatically install tools when entering a directory with .mise.toml
auto_install = true
# Use cargo-binstall for faster installation of cargo tools
cargo.binstall = true
# Generate shims for compatibility with editors/IDEs
experimental = true
# Use precompiled Python binaries only (avoid compilation issues)
python.compile = false

[tools]
# Language runtimes
{{ if (index . "install_web_dev" | default false) -}}
node = "lts"
bun = "latest"
deno = "latest"
{{ end -}}

{{ if (index . "install_go" | default false) -}}
go = "latest"
{{ end -}}

{{ if (index . "install_python" | default false) -}}
python = "latest"
# Python package manager
uv = "latest"
{{ end -}}

# Cargo binary installer
cargo-binstall = "latest"

# CLI tools (using aqua backend for pre-built binaries when available)
eza = "latest"
ripgrep = "latest"
fd = "latest"
fzf = "latest"
tree-sitter = "latest"
yq = "latest"
sccache = "latest"

# Repository management
{{ if .install_static_curl -}}
"aqua:stunnel/static-curl" = "latest"
{{ end -}}
"aqua:x-motemen/ghq" = "latest"
"aqua:k1LoW/roots" = "latest"
"github:k1LoW/git-wt" = "latest"

{{ if (index . "install_neovim_env" | default false) -}}
# Neovim version manager (pre-built binary via aqua)
bob = "latest"
{{ end -}}

# Fuzzy finder for filepaths (Zig-based, pre-built binary)
"aqua:natecraddock/zf" = "latest"

# Tools that need to be compiled from source via cargo
# Note: Rust must be installed via rustup before these can be built
"cargo:sheldon" = "latest"
{{ if (index . "install_rust_tools" | default false) -}}
"cargo:cargo-update" = "latest"
"cargo:rustowl" = "latest"
{{ end -}}

{{ if and (eq .chezmoi.os "linux") (index . "install_tex" | default false) -}}
# TinyTeX for LaTeX (Linux only - macOS uses MacTeX)
tinytex = "latest"
{{ end -}}

{{ if (index . "install_typst" | default false) -}}
# Typst and related tools
typst = "latest"
tinymist = "latest"
{{ end -}}

[env]
# Ensure mise shims and global bun binaries are in PATH
_.path = ["~/.local/share/mise/shims", "~/.bun/bin"]

