#!/bin/bash
# Install system packages required for dotfiles
# This script runs once before chezmoi applies the dotfiles

set -euo pipefail

echo "==> Installing system packages..."

# Check if sudo is available and functional
can_sudo() {
    if command -v sudo >/dev/null 2>&1; then
        # Check if we can run sudo without password or if we are in an interactive terminal
        if sudo -n true 2>/dev/null || [[ -t 0 ]]; then
            return 0
        fi
    fi
    return 1
}

HAS_SUDO=false
if can_sudo; then
    HAS_SUDO=true
else
    echo "Warning: No sudo permissions or not in an interactive terminal. System package installation will be skipped."
fi

install_mise_fallback() {
    if command -v curl &>/dev/null; then
        echo "Falling back to official installer for mise..."
        curl https://mise.run | sh || echo "Warning: Failed to install mise via official installer."
    elif command -v wget &>/dev/null; then
        echo "Falling back to official installer for mise (using wget)..."
        wget -qO- https://mise.run | sh || echo "Warning: Failed to install mise via official installer."
    else
        echo "Warning: Neither curl nor wget found. Cannot install mise."
    fi
}

install_rustup_fallback() {
    if command -v curl &>/dev/null; then
        echo "Installing rustup..."
        curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path || echo "Warning: Failed to install rustup."
    elif command -v wget &>/dev/null; then
        echo "Installing rustup..."
        wget -qO- https://sh.rustup.rs | sh -s -- -y --no-modify-path || echo "Warning: Failed to install rustup."
    else
        echo "Warning: Neither curl nor wget found. Cannot install rustup."
    fi
}

{{ if eq .chezmoi.os "darwin" -}}
# macOS: Detect package manager and install packages

PKG_MANAGER=""

install_packages_brew() {
    brew install \
        zsh \
        git \
        curl
}

install_packages_port() {
    if [ "$HAS_SUDO" = true ]; then
        sudo port selfupdate
        sudo port install \
            zsh \
            git \
            curl
    else
        echo "Skipping MacPorts installation: requires sudo."
    fi
}

# Detect package manager
if command -v brew &>/dev/null; then
    PKG_MANAGER="brew"
    install_packages_brew
elif command -v port &>/dev/null; then
    PKG_MANAGER="port"
    install_packages_port
else
    echo "No supported package manager found. Attempting to install Homebrew..."
    if command -v curl &>/dev/null; then
        # Homebrew installer handles its own sudo prompts or uses user-local install
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" || echo "Warning: Failed to install Homebrew."

        if [[ -x /opt/homebrew/bin/brew ]]; then
            eval "$(/opt/homebrew/bin/brew shellenv)"
        elif [[ -x /usr/local/bin/brew ]]; then
            eval "$(/usr/local/bin/brew shellenv)"
        fi

        if command -v brew &>/dev/null; then
            PKG_MANAGER="brew"
            install_packages_brew
        fi
    else
        echo "Warning: curl not found, cannot install Homebrew."
    fi
fi

# Install mise if not present
if ! command -v mise &>/dev/null; then
    case "$PKG_MANAGER" in
        brew)
            echo "Installing mise via Homebrew..."
            if ! brew install mise; then
                install_mise_fallback
            fi
            ;;
        port)
            echo "Installing mise via MacPorts..."
            if [ "$HAS_SUDO" = true ]; then
                if ! sudo port install mise; then
                    install_mise_fallback
                fi
            else
                echo "Skipping mise via MacPorts: requires sudo."
                install_mise_fallback
            fi
            ;;
        *)
            echo "Installing mise via official installer..."
            install_mise_fallback
            ;;
    esac
fi

# Install rustup if not present
if ! command -v rustup &>/dev/null; then
    install_rustup_fallback
fi

{{ else if eq .chezmoi.os "linux" -}}
# Linux: Detect package manager and install packages

PKG_MANAGER=""

install_packages_apt() {
    if [ "$HAS_SUDO" = true ]; then
        sudo apt-get update
        sudo apt-get install -y \
            zsh \
            git \
            curl \
            unzip \
            build-essential \
            pkg-config \
            libssl-dev \
            libclang-dev \
            socat
    else
        echo "Skipping apt-get installation: requires sudo."
    fi
}

install_packages_dnf() {
    if [ "$HAS_SUDO" = true ]; then
        sudo dnf install -y \
            zsh \
            git \
            curl \
            unzip \
            gcc \
            gcc-c++ \
            make \
            openssl-devel \
            clang-devel \
            socat
    else
        echo "Skipping dnf installation: requires sudo."
    fi
}

install_packages_pacman() {
    if [ "$HAS_SUDO" = true ]; then
        sudo pacman -Syu --noconfirm \
            zsh \
            git \
            curl \
            unzip \
            base-devel \
            openssl \
            clang \
            socat
    else
        echo "Skipping pacman installation: requires sudo."
    fi
}

# Detect package manager
if command -v apt-get &>/dev/null; then
    PKG_MANAGER="apt"
    install_packages_apt
elif command -v dnf &>/dev/null; then
    PKG_MANAGER="dnf"
    install_packages_dnf
elif command -v pacman &>/dev/null; then
    PKG_MANAGER="pacman"
    install_packages_pacman
else
    echo "Warning: Unknown package manager or no sudo access. Please install packages manually."
fi

# Install mise if not present
if ! command -v mise &>/dev/null; then
    case "$PKG_MANAGER" in
        apt)
            echo "Installing mise via apt..."
            if [ "$HAS_SUDO" = true ]; then
                if ! sudo apt-get install -y mise; then
                    install_mise_fallback
                fi
            else
                echo "Skipping mise via apt: requires sudo."
                install_mise_fallback
            fi
            ;;
        dnf)
            echo "Installing mise via dnf..."
            if [ "$HAS_SUDO" = true ]; then
                if ! sudo dnf install -y mise; then
                    install_mise_fallback
                fi
            else
                echo "Skipping mise via dnf: requires sudo."
                install_mise_fallback
            fi
            ;;
        pacman)
            echo "Installing mise via pacman..."
            if [ "$HAS_SUDO" = true ]; then
                if ! sudo pacman -S --noconfirm --needed mise; then
                    install_mise_fallback
                fi
            else
                echo "Skipping mise via pacman: requires sudo."
                install_mise_fallback
            fi
            ;;
        *)
            echo "Installing mise via official installer..."
            install_mise_fallback
            ;;
    esac
fi

# Install rustup if not present
if ! command -v rustup &>/dev/null; then
    install_rustup_fallback
fi

{{ end -}}

echo "==> System packages installed successfully."