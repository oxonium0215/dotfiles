#!/bin/bash
# Setup mise and install tools
# This script runs automatically whenever the mise config changes
# config.toml.tmpl hash: {{ include "dot_config/mise/config.toml.tmpl" | sha256sum }}
# variables hash: {{ (print .install_tex .install_typst .install_web_dev .install_python .install_go .install_rust_tools .install_neovim_env .install_atcoder_tools) | sha256sum }}

set -euo pipefail

echo "==> Setting up mise and installing tools..."

# Ensure local bin and mise shims are in PATH
export PATH="$HOME/.local/bin:$HOME/.local/share/mise/shims:$PATH"

# Source cargo environment if available (for cargo packages)
if [[ -f "$HOME/.cargo/env" ]]; then
    source "$HOME/.cargo/env"
fi

# Ensure mise is available
if ! command -v mise &>/dev/null; then
    echo "Warning: mise is not installed. Skipping tool installation. Please install mise manually and re-run chezmoi apply."
    exit 0
fi

# Trust the mise config
mise trust --all

# Install all tools defined in the global config
echo "Installing tools via mise (this may take a while)..."
mise install

# Reshim to ensure all shims are up to date
mise reshim

# Verify key tools are installed
echo "Verifying tool installation..."
mise list

echo "==> mise setup completed successfully."